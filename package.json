{
  "name": "deze-labs",
  "version": "0.1.0",
  "description": "Personal portfolio hub for Deze Labs, created by Paul (Xyrus).",
  "author": "Paul (Xyrus) <https://github.com/xyrusL>",
  "homepage": "https://github.com/xyrusL/deze",
  "repository": {
    "type": "git",
    "url": "https://github.com/xyrusL/deze.git"
  },
  "bugs": {
    "url": "https://github.com/xyrusL/deze/issues"
  },
  "private": true,
  "scripts": {
    "build": "next build",
    "build:rio-css": "node scripts/build-rio-css.mjs",
    "dev": "concurrently -k -n next,css \"npm:dev:next\" \"npm:dev:css\"",
    "dev:css": "chokidar \"public/assets/css/riostyle.raw.css\" -c \"node scripts/build-rio-css.mjs\"",
    "dev:next": "next dev",
    "start": "next start",
    "lint": "eslint",
    "prebuild": "npm run build:rio-css",
    "predev": "npm run build:rio-css"
  },
  "dependencies": {
    "country-flag-icons": "^1.6.15",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-icons": "^5.6.0",
    "websecure-ez": "^1.0.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "lightningcss": "^1.32.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
